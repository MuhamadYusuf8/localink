# ==============================================================
# ECONOMIC SURVIVAL — Environment Variables
# Platform Marketplace Pertanian Indonesia
# ==============================================================
# Salin file ini menjadi .env.local (Next.js) dan .env (Laravel)
# JANGAN pernah commit file .env asli ke version control
# ==============================================================

# ─────────────────────────────────────
# APP GENERAL
# ─────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
APP_ENV=local
APP_NAME="Economic Survival"
APP_KEY=

# ─────────────────────────────────────
# DATABASE (PostgreSQL 16)
# ─────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=economic_survival
DB_USERNAME=postgres
DB_PASSWORD=

# ─────────────────────────────────────
# SUPABASE (Realtime + Auth + Storage)
# ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─────────────────────────────────────
# LARAVEL AUTH (Sanctum + JWT)
# ─────────────────────────────────────
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# ─────────────────────────────────────
# MIDTRANS (Payment Gateway Indonesia)
# ─────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
# Sandbox: https://app.sandbox.midtrans.com/snap/snap.js
# Production: https://app.midtrans.com/snap/snap.js
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# ─────────────────────────────────────
# REDIS (Queues, Cache, Sessions)
# ─────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─────────────────────────────────────
# STORAGE (AWS S3 atau Supabase Storage)
# ─────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_URL=

# ─────────────────────────────────────
# MAPS & GEOLOCATION
# ─────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BACKEND_KEY=

# ─────────────────────────────────────
# EMAIL (MailHog untuk local dev)
# ─────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@economic-survival.id
MAIL_FROM_NAME="Economic Survival"

# ─────────────────────────────────────
# LOGGING
# ─────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────
# API VERSIONING
# ─────────────────────────────────────
API_VERSION=v1

# ─────────────────────────────────────
# COMMISSION RATES (dalam desimal)
# ─────────────────────────────────────
COMMISSION_RATE_FREE=0.07
COMMISSION_RATE_BASIC=0.05
COMMISSION_RATE_PRO=0.03

# ─────────────────────────────────────
# SUBSCRIPTION PRICES (dalam Rupiah)
# ─────────────────────────────────────
SUBSCRIPTION_PRICE_BASIC=99000
SUBSCRIPTION_PRICE_PRO=299000
